{
	// 如果您是通过uni_modules形式引入uView，可以忽略此配置
	"easycom": {
		"^u-(.*)": "@/uni_modules/uview-ui/components/u-$1/u-$1.vue"
	},
	"window": {
		"navigationStyle": "custom"
	},
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "mainPage/home",
			"style": {
				"usingComponents": { // 组件引入
					// "citycom": "/subPages/sub1/components/citycom",
					"home": "/subPages/switch/components/home"
				},
				"componentPlaceholder": { // 配置组件占位符，在组件包没加载时，暂时使用占位符组件
					// "citycom": "view",
					"home": "view"
				},
				"navigationStyle": "custom"
			}
		},
		{
			"path": "mainPage/person",
			"style": {
				"navigationBarTitleText": "我的",
				"navigationStyle": "custom",
				"usingComponents": { // 组件引入
					"person": "/subPages/switch/components/person"
				},
				"componentPlaceholder": { // 配置组件占位符，在组件包没加载时，暂时使用占位符组件
					"person": "view"
				}
			}
		},
		{
			"path": "mainPage/baohan",
			"style": {
				"navigationBarTitleText": "保函",
				"usingComponents": { // 组件引入
					"baohan": "/subPages/switch/components/baohan"
				},
				"componentPlaceholder": { // 配置组件占位符，在组件包没加载时，暂时使用占位符组件
					"baohan": "view"
				}
			}
		}
		,
		{
			"path": "mainPage/index",
			"style": {
				"navigationBarTitleText": "文件上传"
			}
		}
		,
		{
			"path": "mainPage/test",
			"style": {
				"navigationBarTitleText": "文件上传text"
			}
		}
		//#ifdef WEB
		,
		{
			"path": "mainPage/dingdan",
			"style": {
				"navigationBarTitleText": "订单",
				"usingComponents": { // 组件引入
					"dingdan": "/subPages/switch/components/dingdan"
				},
				"componentPlaceholder": { // 配置组件占位符，在组件包没加载时，暂时使用占位符组件
					"dingdan": "view"
				}
			}
		},
		{
			"path": "mainPage/look",
			"style": {
				"navigationBarTitleText": "文件预览"
			}
		}
		//#endif
	],
	//分包加载配置，此配置为小程序的分包加载机制。
	"subPackages": [
		{
			"root": "subPages/sub1",
			"pages": [
				{
					"path": "login",
					"style": {
						"navigationStyle": "custom",
						"navigationBarTitleText": "登录"
					}
				},
				{
					"path": "register",
					"style": {
						"navigationBarTitleText": "注册"
					}
				},
				{
					"path": "password",
					"style": {
						"navigationBarTitleText": "找回密码"
					}
				},
				{
					"path": "demo",
					"style": {
						"navigationBarTitleText": "demo"
					}
				}
			]
		}
	],
	// "preloadRule": {
	// 	"mainPage/home": {
	// 		"network": "all",
	// 		"packages": ["subPages/sub1"]
	// 	}
	// },
	"globalStyle": {
		"rpxCalcMaxDeviceWidth": 960, // rpx 计算所支持的最大设备宽度，单位 px，默认值为 960
		"rpxCalcBaseDeviceWidth": 375, // rpx 计算使用的基准设备宽度，设备实际宽度超出 rpx 计算所支持的最大设备宽度时将按基准宽度计算，单位 px，默认值为 375
		"rpxCalcIncludeWidth": 750, // rpx 计算特殊处理的值，始终按实际的设备宽度计算，单位 rpx，默认值为 750
		"navigationBarTextStyle": "white",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#cf2135",
		"backgroundColor": "#F8F8F8"
	},
	"uniIdRouter": {},
	"tabBar": {
		"color": "#909399", //字体颜色
		"selectedColor": "#cf2135", //选中的颜色
		"borderStyle": "black", //边框色
		"backgroundColor": "#ffffff", //背景色
		"list": [
			{
				"pagePath": "mainPage/home",
				"iconPath": "static/a1.png",
				"selectedIconPath": "static/a2.png",
				"text": "首页"
			},
			{
				"pagePath": "mainPage/baohan",
				"iconPath": "static/b1.png",
				"selectedIconPath": "static/b2.png",
				"text": "保函"
			},
			//#ifdef WEB
			{
				"pagePath": "mainPage/dingdan",
				"iconPath": "static/c1.png",
				"selectedIconPath": "static/c2.png",
				"text": "订单"
			},
			//#endif
			{
				"pagePath": "mainPage/person",
				"iconPath": "static/d1.png",
				"selectedIconPath": "static/d2.png",
				"text": "我的"
			}
		]
	}
}
